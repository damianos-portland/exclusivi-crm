# ── Βάση δεδομένων ───────────────────────────────────────────────
# Τοπικά: SQLite. Στο Vercel: Neon Postgres (άλλαξε provider σε "postgresql"
# στο prisma/schema.prisma).
DATABASE_URL="file:./dev.db"

# ── Auth ─────────────────────────────────────────────────────────
AUTH_SECRET="βάλε-ένα-τυχαίο-μυστικό-32+-χαρακτήρες"

# Στοιχεία του CEO (χρησιμοποιούνται από το seed)
ADMIN_EMAIL="ceo@exclusivi.gr"
ADMIN_NAME="Exclusivi CEO"
ADMIN_PASSWORD="άλλαξέ-το"

# ── Email (Gmail / Google Workspace) ─────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="account@exclusivi.gr"
SMTP_PASS="16ψήφιο-app-password"

# ── Cron (προαιρετικό) ───────────────────────────────────────────
# Μυστικό για προστασία του /api/cron/reminders
CRON_SECRET=""
